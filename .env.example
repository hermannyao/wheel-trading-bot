# Wheel Trading Bot Configuration

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_DEBUG=false

# Database
DATABASE_URL=sqlite:///./wheel_bot.db

# CORS - comma separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO

# Scanner
SP500_SOURCE_URL=https://en.wikipedia.org/wiki/List_of_S%26P_500_companies
SP500_LOCAL_FILE=backend/sp500_symbols.txt
SP500_EXCLUDE_FILE=backend/sp500_exclude.txt
WHEEL_SYMBOLS=AAPL,MSFT,AMZN,NVDA,TSLA,META,GOOGL
MIN_DTE=21
MAX_DTE=45
TARGET_OTM_PCT=0.05
MIN_OPEN_INTEREST=10
MIN_IV=0.20
MIN_APR=8.0
DELTA_MIN=0.20
DELTA_MAX=0.40
MAX_SPREAD_PCT=0.25
MAX_WORKERS=10
RISK_FREE_RATE=0.02
MAX_BUDGET_PER_TRADE=3000
MAX_TOTAL_BUDGET=3000

# API Keys (if using premium data sources)
# YFINANCE_API_KEY=your_api_key_here

# Frontend
VITE_API_BASE_URL=http://localhost:8000
